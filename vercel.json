{
  "buildCommand": "npm run build",
  "outputDirectory": "build",
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Content-Type",
          "value": "application/xml; charset=utf-8"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/(?!api/|_next/|static/|public/|sitemap.xml|robots.txt|favicon.ico)(.*)",
      "destination": "/index.html"
    }
  ]
}